// Test database — use a separate DB so tests never touch your real data.
// Copy this to .env.test and set a different DB name.
# Server
PORT=3000

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://user:password@localhost:5432/simpul_test"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://user:password@localhost:5432/simpul_test"

# --- Auth ---
JWT_SECRET="test-secret-not-for-production"
JWT_EXPIRES_IN="7d"

# --- Payment gateway (PJP Kategori 1) ---
# Get sandbox keys by signing up at dashboard.xendit.co (test mode, no business docs needed)
# or dashboard.sandbox.midtrans.com. Pick ONE provider for the hackathon; don't build both.
PJP_PROVIDER="midtrans"           # "xendit" | "midtrans"
XENDIT_SECRET_KEY="xnd_development_..."
XENDIT_CALLBACK_TOKEN="..."     # used to verify incoming webhooks are really from Xendit
MIDTRANS_SERVER_KEY="SB-Mid-server-..."
MIDTRANS_IS_PRODUCTION="false"

# --- AI Wedding Assistant ---
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# --- Server ---
PORT=4000
CORS_ORIGIN="http://localhost:8080"
